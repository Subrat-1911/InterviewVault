generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 🔒 TABLE 1: USER AUTH DATA
// ==========================================
model User {
  id           String   @id @default(uuid())
  clerkUserId  String   @unique // Clerk ID save karne ke liye
  email        String   @unique // User ka email
  name         String?  // Optional name
  createdAt    DateTime @default(now())
}



// 🏢 ONLY TABLE 2: COMPANY MASTER DETAILS
model Company {
  id               String   @id // e.g., "amazon", "google", "graviton" (lowercase URL slugs)
  name             String   // Real Display Name e.g., "Amazon India"
  sector           String   // e.g., "Software", "Quant", "Core"
  
  // Placement Metrics
  grossCtc         String   // e.g., "34.0 LPA"
  cpiCutoff        Float    @default(0.0) // e.g., 7.50
  allowedBranches  String[] // Array format: ["CSE", "EE", "EP"]
  allowedDegrees   String[] // Array format: ["B.Tech", "DD"]
  
  // Round & Process Specs
  testPlatform     String   // e.g., "HackerRank"
  testPattern      String   // e.g., "2 Coding Questions + 15 Aptitude MCQs"
  interviewRounds  String   // e.g., "3 Technical Rounds (DSA) + 1 HR"

  createdAt        DateTime @default(now())
}